# Cloud provider API keys (at least one required for live orchestration)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional local models — do not block cloud usage when unset
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_ENABLED=false
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Fusion settings
FUSION_DB_PATH=./fusion_runs.db
FUSION_LOG_RAW_PROMPTS=false
# Agent mode: allow MCP agent to read/write files and run shell in workspace
FUSION_AGENT_MODE=false
FUSION_WORKSPACE_ROOT=.
# Set to "mock" only for offline development/tests
# FUSION_DEFAULT_PROVIDER=mock
